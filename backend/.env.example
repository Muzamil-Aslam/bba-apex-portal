# ── Server ──────────────────────────────────────────────────────
PORT=5001
NODE_ENV=production

# ── MongoDB Atlas ────────────────────────────────────────────────
MONGO_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/bba_apex_portal?retryWrites=true&w=majority

# ── JWT ──────────────────────────────────────────────────────────
JWT_SECRET=change_this_to_a_long_random_string_minimum_32_chars
JWT_EXPIRE=7d

# ── Cloudinary (optional — for poster/gallery image uploads) ─────
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# ── Gmail SMTP (for OTP + registration confirmation emails) ──────
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_gmail@gmail.com
EMAIL_PASS=your_16_char_gmail_app_password

# ── CORS ─────────────────────────────────────────────────────────
# FRONTEND_URL     = your Vercel deployment URL
# FRONTEND_URL_PROD = your custom domain (add later when you have one)
FRONTEND_URL=https://your-app-name.vercel.app
FRONTEND_URL_PROD=https://your-custom-domain.com
